{
  "name": "@g14o/cache",
  "version": "0.2.0",
  "description": "Cache middleware for Next.js with in-memory dev backends and Upstash Redis in production.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "prepack": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@g14o/utils": "workspace:^0.2.0",
    "@upstash/redis": "^1.34.0"
  },
  "peerDependencies": {
    "next": ">=15"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@workspace/typescript-config": "workspace:*",
    "next": "16.2.6",
    "dotenv": "^16.6.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "keywords": [
    "nextjs",
    "cache",
    "redis",
    "upstash"
  ],
  "engines": {
    "node": ">=20"
  }
}
